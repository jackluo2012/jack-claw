workspace:
  id: "jackclaw-default"
  name: "JackClaw 工作助手"

feishu:
  # 必填：从飞书开放平台应用配置中获取
  app_id: "${FEISHU_APP_ID}"
  app_secret: "${FEISHU_APP_SECRET}"
  # 可选：事件加密/验证相关配置，如未启用可留空
  encrypt_key: ""
  verification_token: ""

bot:
  loading_message: "思考中..."
  prefix: ""

agent:
  model: "qwen3-max"
  max_iter: 50
  max_input_tokens: 30000
  sub_agent_model: "qwen3-max"
  sub_agent_max_iter: 20
  timeout_s: 300

skills:
  global_dir: "../skills"
  local_dir: "./skills"

sandbox:
  url: "http://localhost:8022/mcp"   # sandbox-docker-compose.yaml 映射 8022:8080
  workspace_dir: "/workspace"
  timeout_s: 120
  max_retries: 2

memory:
  # workspace 目录：Bootstrap 读取 soul.md / user.md / agent.md / memory.md
  # 初始文件见 workspace-init/（复制到此目录后按实际情况修改）
  workspace_dir: "./data/workspace"
  # ctx.json / raw.jsonl 存储目录（跨 session 上下文压缩快照）
  ctx_dir: "./data/ctx"
  # pgvector 连接串（空字符串时跳过搜索记忆索引）
  # 格式：postgresql://jackclaw:jackclaw123@localhost:5432/jackclaw_memory
  db_dsn: "${MEMORY_DB_DSN:-postgresql://jackclaw:jackclaw123@localhost:5432/jackclaw_memory}"

session:
  max_history_turns: 20

runner:
  queue_idle_timeout_s: 300
  max_queue_size: 10

sender:
  max_retries: 3
  retry_backoff: [1, 2, 4]

data_dir: "./data"

debug:
  enable_test_api: false
  test_api_port: 9090
  test_api_host: "127.0.0.1"